## 4. 시간 임계치 (config.rs 상수)

모든 시간 파라미터는 물리적 제약에서 도출.

```rust
// ── PLI Governor 레이어별 차등 ──

/// PLI 유실 대비 재전송 타임아웃
const PLI_RETRY_TIMEOUT_H: Duration     = Duration::from_millis(1500); // h I-Frame 생성 느림
const PLI_RETRY_TIMEOUT_L: Duration     = Duration::from_millis(500);  // l I-Frame 가벼움

/// 같은 publisher에게 PLI 최소 간격 (물리적 하한)
const PLI_MIN_INTERVAL_H: Duration      = Duration::from_millis(300);  // h 인코딩 비용 큼
const PLI_MIN_INTERVAL_L: Duration      = Duration::from_millis(100);  // l은 더 관대

/// 릴레이 유실 대비 — I-Frame 왔는데 subscriber에게 안 간 경우
const PLI_STALE_KEYFRAME_TIMEOUT: Duration = Duration::from_secs(2);

/// 자동 다운그레이드 트리거 — 연속 PLI 횟수
const PLI_DOWNGRADE_THRESHOLD_H: u32    = 3;   // h에서 PLI 3회 연속 → l로
const PLI_DOWNGRADE_THRESHOLD_L: u32    = 5;   // l에서도 반복이면 pause 검토

/// 자동 업그레이드 복귀 — 안정 관찰 기간
const PLI_UPGRADE_STABLE_PERIOD: Duration = Duration::from_secs(5);

/// 업그레이드 백오프 (진동 방지)
const PLI_UPGRADE_BACKOFF_BASE: Duration  = Duration::from_secs(5);
const PLI_UPGRADE_BACKOFF_MAX: Duration   = Duration::from_secs(60);
// 실제 대기 = min(base * 2^downgrade_count, max)
// 1차: 5s, 2차: 10s, 3차: 20s, 4차: 40s, 5차+: 60s
```

